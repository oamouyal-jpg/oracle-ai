# Render production: set INTERNAL_API_URL to your API URL (e.g. https://oracle-api.onrender.com)
INTERNAL_API_URL=
# Optional — browser calls API directly (needs CORS). Leave empty to use /api proxy in production.
NEXT_PUBLIC_API_URL=
# Local direct API:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:4000
# INTERNAL_API_URL=http://127.0.0.1:4000
